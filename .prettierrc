{
    "tabWidth": 4,
    "semi": true,
    "singleQuote": false,
    "quoteProps": "consistent",
    "trailingComma": "es5",
    "printWidth": 80,
    "endOfLine": "auto",
    "overrides": [
        {
            "files": ".github/**/*.{yml,yaml}",
            "options": {
                "tabWidth": 2,
                "singleQuote": true
            }
        }
    ]
}
