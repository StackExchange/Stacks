// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`atomic: floats > should output all atomic floats classes 1`] = `
".float-left {
    float: left !important;
}

.float-right {
    float: right !important;
}

.float-none {
    float: none !important;
}

.clearfix:before,
.clearfix:after {
    content: "";
    display: table;
}

.clearfix:after {
    clear: both;
}

.clear-left {
    clear: left !important;
}

.clear-right {
    clear: right !important;
}

.clear-both {
    clear: both !important;
}

.clear-none {
    clear: none !important;
}
"
`;
