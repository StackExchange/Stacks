{
    "name": "@stackoverflow/stacks-email",
    "description": "Stack Overflow email components, templates, and compilation tools",
    "version": "0.0.1",
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/types/src/lib/api/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/types/src/lib/api/index.d.ts",
            "import": "./dist/index.js"
        },
        "./sveltekit": {
            "types": "./dist/types/src/lib/sveltekit/index.d.ts",
            "import": "./dist/sveltekit.js"
        }
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "dev": "vite dev",
        "prebuild": "npm run build -w @stackoverflow/stacks && npm run build -w @stackoverflow/stacks-svelte",
        "build": "npm run build:package && npm run build:gallery",
        "build:package": "vite build --config vite.package.config.ts && tsc --project tsconfig.build.json",
        "build:gallery": "vite build",
        "preview": "vite preview",
        "prepare": "svelte-kit sync || echo ''",
        "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
        "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
        "lint": "npm run check && eslint .",
        "format": "prettier --write .",
        "test": "vitest run",
        "test:watch": "vitest watch"
    },
    "devDependencies": {
        "@sveltejs/adapter-auto": "^6.1.0",
        "@sveltejs/kit": "^2.48.5",
        "@sveltejs/vite-plugin-svelte": "^6.2.1",
        "@stackoverflow/stacks": "*",
        "@stackoverflow/stacks-icons": "^7.0.0-beta.25",
        "@stackoverflow/stacks-svelte": "*",
        "@types/mjml": "^5.0.0",
        "eslint": "^9.39.2",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-svelte": "^3.14.1",
        "globals": "^17.0.0",
        "highlight.js": "^11.11.1",
        "mdsvex": "^0.12.3",
        "prettier": "^3.8.3",
        "prettier-plugin-svelte": "^3.4.0",
        "svelte": "^5.55.9",
        "svelte-check": "^4.3.5",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.53.0",
        "vite": "^7.3.3",
        "vitest": "^4.1.10"
    },
    "dependencies": {
        "markdown-it": "^14.1.0",
        "mjml": "^4.17.1",
        "zod": "^4.1.12"
    },
    "peerDependencies": {
        "@sveltejs/kit": "^2.48.5"
    },
    "peerDependenciesMeta": {
        "@sveltejs/kit": {
            "optional": true
        }
    }
}
