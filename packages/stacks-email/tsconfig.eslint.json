{
    "extends": "./tsconfig.json",
    "include": [
        "./.svelte-kit/ambient.d.ts",
        "./.svelte-kit/non-ambient.d.ts",
        "./.svelte-kit/types/**/$types.d.ts",
        "./components/**/*.ts",
        "./templates/**/*.ts",
        "./src/**/*.js",
        "./src/**/*.ts",
        "./src/**/*.svelte",
        "./eslint.config.js",
        "./svelte.config.js",
        "./vite.config.ts",
        "./vite.package.config.ts"
    ],
    "exclude": ["./.svelte-kit/output/**", "./node_modules/**"]
}
