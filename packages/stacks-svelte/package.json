{
    "name": "@stackoverflow/stacks-svelte",
    "description": "Stacks Components built in Svelte",
    "type": "module",
    "version": "1.0.0-beta.17",
    "exports": {
        ".": {
            "types": "./lib/components/index.d.ts",
            "svelte": "./lib/components/index.js"
        },
        "./actions": {
            "types": "./lib/actions/index.d.ts",
            "import": "./lib/actions/index.js"
        }
    },
    "scripts": {
        "build": "svelte-package -i src -o lib && rimraf test-utils.d.ts",
        "build:stacks-classic": "echo 'Building stacks-classic because web-test-runner.config.mjs needs dist/css/stacks.css' && npm run build -w ../stacks-classic", 
        "build:stacks-utils": "echo 'Building stacks-utils because it's needed by svelte-check for linting' && npm run build -w ../stacks-utils",
        "format": "prettier --write .",
        "lint": "npm run build:stacks-utils && svelte-check && eslint .",
        "lint:fix": "eslint . --fix",
        "test": "npm run build:stacks-classic && web-test-runner && npm run test:tools",
        "test:watch": "npm run build:stacks-classic && web-test-runner --watch",
        "test:tools": "npm run storybook:build && node --test tools/*.test.js",
        "storybook": "storybook dev -p 6006",
        "storybook:build": "npm run build:stacks-classic && storybook build -o netlify/dist && npm run storybook:extract",
        "storybook:extract": "node tools/storybook-llms-extractor.js"
    },
    "peerDependencies": {
        "@stackoverflow/stacks": "^3.0.0-beta.15",
        "@stackoverflow/stacks-utils": "*",
        "svelte": "^5.0.0"
    },
    "dependencies": {
        "@floating-ui/core": "^1.7.3",
        "@stackoverflow/stacks-icons": "^7.0.0-beta.14",
        "@stackoverflow/stacks-icons-legacy": "npm:@stackoverflow/stacks-icons@^6.9.0",
        "svelte-floating-ui": "^1.6.2",
        "svelte-sonner": "^1.0.5"
    },
    "files": [
        "lib",
        "!lib/**/*.test.*",
        "!lib/**/*.stories.*"
    ]
}
