{
  "name": "@stackeng/stacks-svelte",
  "description": "Stacks Components built in Svelte",
  "license": "UNLICENSED",
  "type": "module",
  "version": "0.3.2",
  "exports": {
    ".": {
      "types": "./lib/components/index.d.ts",
      "svelte": "./lib/components/index.js"
    },
    "./actions": {
      "types": "./lib/actions/index.d.ts",
      "import": "./lib/actions/index.js"
    }
  },
  "scripts": {
    "build": "svelte-package -i src -o lib && rimraf test-utils.d.ts",
    "format": "prettier --write .",
    "lint": "svelte-check && eslint .",
    "lint:fix": "eslint . --fix",
    "test": "web-test-runner",
    "test:watch": "web-test-runner --watch",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build",
    "version": "changeset version && npm install --package-lock-only",
    "release": "npm run build && changeset publish"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.5.1",
    "@changesets/cli": "^2.29.6",
    "@open-wc/testing": "^4.0.0",
    "@remcovaes/web-test-runner-vite-plugin": "^1.3.0",
    "@stackoverflow/prettier-config": "^1.0.0",
    "@stackoverflow/stacks": "^2.8.4",
    "@storybook/addon-docs": "^9.1.5",
    "@storybook/addon-links": "^9.1.3",
    "@storybook/addon-svelte-csf": "^5.0.8",
    "@storybook/svelte": "^9.1.5",
    "@storybook/svelte-vite": "^9.1.5",
    "@sveltejs/package": "^2.5.0",
    "@sveltejs/vite-plugin-svelte": "^5.1.0",
    "@testing-library/svelte": "^5.2.8",
    "@testing-library/user-event": "^14.6.1",
    "@types/babel__core": "^7.20.5",
    "@types/mocha": "^10.0.10",
    "@typescript-eslint/parser": "^8.42.0",
    "@web/test-runner": "^0.20.2",
    "@web/test-runner-commands": "^0.9.0",
    "@web/test-runner-playwright": "^0.11.1",
    "chai-dom": "^1.12.1",
    "eslint": "^9.35.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-chai-friendly": "^1.1.0",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-svelte": "^3.10.1",
    "globals": "^16.4.0",
    "htm": "^3.1.1",
    "prettier": "^3.6.2",
    "prettier-plugin-svelte": "^3.4.0",
    "rimraf": "^6.0.1",
    "sass": "^1.92.1",
    "sinon": "^20.0.0",
    "storybook": "^9.1.5",
    "svelte": "^5.38.10",
    "svelte-check": "^4.3.1",
    "svelte-preprocess": "^6.0.3",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.42.0",
    "vite": "^6.3.5"
  },
  "peerDependencies": {
    "@stackoverflow/stacks": "^2.8.4",
    "svelte": "^5.0.0"
  },
  "dependencies": {
    "@floating-ui/core": "^1.7.3",
    "@stackoverflow/stacks-icons": "^6.6.1",
    "svelte-floating-ui": "^1.6.2"
  },
  "files": [
    "lib",
    "!lib/**/*.test.*",
    "!lib/**/*.stories.*"
  ]
}
